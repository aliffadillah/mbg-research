---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoginForm from '../features/auth/LoginForm';
---

<BaseLayout title="Masuk — NutriSight">
  <div class="min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-50">
      <div class="absolute top-[20%] left-[10%] w-[400px] h-[400px] rounded-full bg-primary-200/30 blur-[100px]"></div>
      <div class="absolute bottom-[20%] right-[10%] w-[300px] h-[300px] rounded-full bg-accent-200/20 blur-[80px]"></div>
    </div>
    <div class="relative z-10 w-full px-6 py-20">
      <LoginForm client:load />
    </div>
  </div>
</BaseLayout>
