---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatsGrid from '../../features/dashboard/StatsGrid';
import ActivityFeed from '../../features/dashboard/ActivityFeed';
import NutritionCharts from '../../features/dashboard/NutritionCharts';
---

<DashboardLayout title="Dashboard — NutriSight" activeRoute="/dashboard">
  <div class="space-y-8">
    <!-- Page title like Ultralytics -->
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Home</h1>
      <p class="text-sm text-gray-500 mt-0.5">Monitoring nutrisi makanan Anda.</p>
    </div>

    <!-- Welcome card like Ultralytics -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <div class="flex items-center gap-4 mb-5">
        <div class="w-12 h-12 rounded-full bg-[#4361ee] flex items-center justify-center text-white font-bold">U</div>
        <div>
          <div class="flex items-center gap-2">
            <span class="text-base font-semibold text-gray-900">Welcome back</span>
            <span class="text-[10px] bg-primary-100 text-primary-700 px-1.5 py-0.5 rounded font-medium">Free</span>
          </div>
          <p class="text-xs text-gray-400 mt-0.5">NutriSight Platform</p>
        </div>
      </div>
      <div class="border-t border-gray-100 pt-4">
        <StatsGrid client:load />
      </div>
    </div>

    <!-- Grid sections like Ultralytics (Datasets / Projects / Storage) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Nutrition Database (like Datasets) -->
      <div class="bg-white rounded-lg border border-gray-200">
        <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7c-2 0-3 1-3 3z" /></svg>
            <span class="text-sm font-medium text-gray-900">Database Nutrisi</span>
          </div>
          <a href="/dashboard/nutrition" class="text-xs text-[#4361ee] hover:underline font-medium">View all →</a>
        </div>
        <div class="p-5">
          <p class="text-xs text-gray-400 mb-4">Data makanan Indonesia beserta kandungan nutrisinya.</p>
          <div class="space-y-2">
            <a href="/dashboard/nutrition" class="flex items-center justify-between py-2 px-3 rounded-md hover:bg-gray-50 transition-colors border border-gray-100 group">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded bg-emerald-100 text-emerald-600 flex items-center justify-center text-[10px] font-bold">P</div>
                <span class="text-sm text-gray-800">Protein</span>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
            <a href="/dashboard/nutrition" class="flex items-center justify-between py-2 px-3 rounded-md hover:bg-gray-50 transition-colors border border-gray-100 group">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded bg-amber-100 text-amber-600 flex items-center justify-center text-[10px] font-bold">K</div>
                <span class="text-sm text-gray-800">Karbohidrat</span>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
            <a href="/dashboard/nutrition" class="flex items-center justify-between py-2 px-3 rounded-md hover:bg-gray-50 transition-colors border border-gray-100 group">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded bg-green-100 text-green-600 flex items-center justify-center text-[10px] font-bold">S</div>
                <span class="text-sm text-gray-800">Sayuran</span>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
            <a href="/dashboard/nutrition" class="flex items-center justify-between py-2 px-3 rounded-md hover:bg-gray-50 transition-colors border border-gray-100 group">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded bg-rose-100 text-rose-600 flex items-center justify-center text-[10px] font-bold">B</div>
                <span class="text-sm text-gray-800">Buah</span>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Detection (like Projects) -->
      <div class="bg-white rounded-lg border border-gray-200">
        <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /></svg>
            <span class="text-sm font-medium text-gray-900">Deteksi Makanan</span>
          </div>
          <a href="/dashboard/detection" class="text-xs bg-[#4361ee] text-white px-3 py-1 rounded-md hover:bg-[#3a56d4] transition-colors font-medium">+ New Scan</a>
        </div>
        <div class="p-5">
          <p class="text-xs text-gray-400 mb-4">Upload foto makanan untuk analisis nutrisi otomatis.</p>
          <!-- Upload hint -->
          <div class="border-2 border-dashed border-gray-200 rounded-lg p-6 text-center">
            <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
            <p class="text-xs text-gray-400">Drop images here</p>
            <p class="text-[10px] text-gray-300 mt-1">JPG, PNG, WebP</p>
          </div>
          <!-- Recent detection items -->
          <div class="mt-4 space-y-2">
            <a href="/dashboard/detection" class="flex items-center gap-3 p-2 rounded-md hover:bg-gray-50 transition-colors group">
              <div class="w-7 h-7 rounded bg-[#4361ee]/10 text-[#4361ee] flex items-center justify-center">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /></svg>
              </div>
              <div>
                <div class="text-xs font-medium text-gray-800">Analisis Makanan</div>
                <div class="text-[10px] text-gray-400">Scan & deteksi nutrisi</div>
              </div>
            </a>
          </div>
        </div>
      </div>

      <!-- Activity / Storage (like Storage panel) -->
      <div class="bg-white rounded-lg border border-gray-200">
        <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="text-sm font-medium text-gray-900">Aktivitas</span>
          </div>
          <a href="/dashboard/history" class="text-xs text-[#4361ee] hover:underline font-medium">View all →</a>
        </div>
        <div class="p-5">
          <ActivityFeed client:load />
        </div>
      </div>
    </div>

    <!-- Data Visualization Charts -->
    <NutritionCharts client:load />
  </div>
</DashboardLayout>
